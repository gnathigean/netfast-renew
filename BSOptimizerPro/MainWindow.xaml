<Window x:Class="BSOptimizerPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        Title="BS OPTIMIZER PRO | DASHBOARD" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BgBrush}"
        WindowStyle="None" AllowsTransparency="True">
    
    <Border CornerRadius="15" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" Background="{StaticResource BgBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="15,0,0,15">
                <Grid Margin="20">
                    <StackPanel>
                        <TextBlock Text="⚡ BS PRO" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,40"/>
                        
                        <Button Content="Início" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalAlignment="Left" Margin="0,10"/>
                        <Button Content="Configurações" Background="Transparent" Foreground="#555555" BorderThickness="0" HorizontalAlignment="Left" Margin="0,10"/>
                        <Button Content="Hacks/Cheats (EM BREVE)" Background="Transparent" Foreground="#333333" BorderThickness="0" HorizontalAlignment="Left" Margin="0,10" IsEnabled="False"/>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock x:Name="UserGreet" Text="Olá, Usuário" Foreground="White" FontWeight="Bold"/>
                        <TextBlock x:Name="LicenseInfo" Text="VIP: 30 Dias" Foreground="{StaticResource SecondaryBrush}" FontSize="12"/>
                        <Button Content="SAIR" Foreground="#ff3a3a" Background="Transparent" BorderThickness="0" Click="Logout_Click" HorizontalAlignment="Left" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
                    <TextBlock Text="DASHBOARD DE PERFORMANCE" FontSize="24" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <UniformGrid Grid.Row="1" Columns="2" Rows="2">
                    <!-- FPS Turbo Card -->
                    <Border Margin="10" Background="{StaticResource CardBrush}" CornerRadius="15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🚀 FPS TURBO" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="Desbloqueia FPS e otimiza .ini do jogo." Foreground="{StaticResource FadedTextBrush}" Margin="0,5,0,20" TextWrapping="Wrap"/>
                            <Button x:Name="FpsBtn" Content="ATIVAR AGORA" Style="{StaticResource PremiumButtonStyle}" Click="ApplyFpsOptimization_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- GPU Opt Card -->
                    <Border Margin="10" Background="{StaticResource CardBrush}" CornerRadius="15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🎮 OTIMIZAR GPU" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}"/>
                            <TextBlock Text="Prioridade máxima para NVIDIA/AMD." Foreground="{StaticResource FadedTextBrush}" Margin="0,5,0,20" TextWrapping="Wrap"/>
                            <Button x:Name="GpuBtn" Content="OTIMIZAR" Style="{StaticResource PremiumButtonStyle}" Click="ApplyGpuOptimization_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Cleaner Card -->
                    <Border Margin="10" Background="{StaticResource CardBrush}" CornerRadius="15" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🧹 LIMPEZA TOTAL" FontSize="18" FontWeight="Bold" Foreground="#facc15"/>
                            <TextBlock Text="Remove caches e arquivos temporários." Foreground="{StaticResource FadedTextBrush}" Margin="0,5,0,20" TextWrapping="Wrap"/>
                            <Button x:Name="CleanBtn" Content="LIMPAR SISTEMA" Style="{StaticResource PremiumButtonStyle}" Background="#facc15" Foreground="Black" Click="ApplyCleanup_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Info Card -->
                    <Border Margin="10" Background="{StaticResource CardBrush}" CornerRadius="15" Padding="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="STATUS" Foreground="{StaticResource FadedTextBrush}"/>
                            <TextBlock x:Name="StatusText" Text="SISTEMA PROTEGIDO" Foreground="{StaticResource SecondaryBrush}" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Grid>
    </Border>
</Window>
