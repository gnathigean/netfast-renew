<Window x:Class="BSOptimizerPro.CrosshairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Netfast Crosshair" Height="100" Width="100"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">
    <Grid x:Name="CrosshairContainer">
        <!-- Mira em Cruz Simples (Centro Verde Neon) -->
        <Canvas HorizontalAlignment="Center" VerticalAlignment="Center" Width="20" Height="20">
            <Line X1="10" Y1="0" X2="10" Y2="8" Stroke="#00e676" StrokeThickness="2" />
            <Line X1="10" Y1="12" X2="10" Y2="20" Stroke="#00e676" StrokeThickness="2" />
            <Line X1="0" Y1="10" X2="8" Y2="10" Stroke="#00e676" StrokeThickness="2" />
            <Line X1="12" Y1="10" X2="20" Y2="10" Stroke="#00e676" StrokeThickness="2" />
            <Ellipse Canvas.Left="9" Canvas.Top="9" Width="2" Height="2" Fill="Red"/>
        </Canvas>
    </Grid>
</Window>
