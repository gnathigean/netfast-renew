<Window x:Class="BSOptimizerPro.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        Title="Netfast Overlay" Height="150" Width="200"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual" Left="10" Top="10">
    
    <Border Background="#AA000000" CornerRadius="8" Padding="10" BorderBrush="#33FFFFFF" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="NETFAST HUD" Foreground="#8b5cf6" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="CPU: " Foreground="#facc15" FontSize="12"/>
                <TextBlock x:Name="TxtCpu" Text="0%" Foreground="White" FontSize="12" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="GPU: " Foreground="#00e676" FontSize="12"/>
                <TextBlock x:Name="TxtGpu" Text="0%" Foreground="White" FontSize="12" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="LATÊNCIA: " Foreground="#ff3a3a" FontSize="12"/>
                <TextBlock x:Name="TxtPing" Text="0ms" Foreground="White" FontSize="12" FontWeight="Bold"/>
            </StackPanel>

            <TextBlock x:Name="TxtStatus" Text="OTIMIZADO" Foreground="#00e676" FontSize="9" Margin="0,5,0,0" HorizontalAlignment="Right"/>
        </StackPanel>
    </Border>
</Window>
